# ─────────────────────────────────────────────────────────────────────────────
# LaunchMint - environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
DATABASE_URL=postgresql://launchmint:launchmint@localhost:5432/launchmint?schema=public
REDIS_URL=redis://localhost:6379

# ─── Auth (NextAuth + Google OAuth) ──────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI (Gemini) ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL_PRO=gemini-1.5-pro
GEMINI_MODEL_FLASH=gemini-1.5-flash

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM=hello@launchmint.com

# ─── Storage (S3 / LocalStack in dev) ────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=launchmint-uploads
S3_PUBLIC_URL=http://localhost:4566/launchmint-uploads
S3_ENDPOINT=http://localhost:4566

# ─── Search (Typesense) ──────────────────────────────────────────────────────
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=dev-typesense-key

# ─── Billing (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ─── Stripe Connect (read-only MRR pull) ─────────────────────────────────────
STRIPE_CLIENT_ID=
STRIPE_CLIENT_SECRET=

# ─── SEO data (DataForSEO) ───────────────────────────────────────────────────
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# ─── Analytics & monitoring ──────────────────────────────────────────────────
POSTHOG_KEY=
POSTHOG_HOST=https://us.posthog.com
SENTRY_DSN=

# ─── Search engine verification (paste tokens from each console) ─────────────
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_VERIFICATION=

# ─── Misc ────────────────────────────────────────────────────────────────────
INDEXNOW_KEY=
CRON_SECRET=replace-with-openssl-rand-hex-32
ENCRYPTION_KEY=replace-with-openssl-rand-base64-32
